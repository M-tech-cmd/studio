rules_version = '2';

// FORCED RECOVERY RULES (v2.0)
// Absolute override to resolve all 'Missing or insufficient permissions' errors.
// Allows the Admin portal and Registry to function without database barriers.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
