rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null && 
             (request.auth.token.email == 'kimaniemma20@gmail.com' || 
              request.auth.uid == 'BKSmmIdohYQHlao5V9eZ9JQyaEV2' ||
              request.auth.uid == 'sxiZRGIEshOkSROfqOFb3UcvP6g1');
    }

    function isAdmin() {
      return isSuperAdmin();
    }

    match /site_settings/{settingsId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    match /inquiries/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /masses/{id} { allow read: if true; allow write: if isAdmin(); }
    match /community_groups/{id} { allow read: if true; allow write: if isAdmin(); }
    match /bulletins/{id} { allow read: if true; allow write: if isAdmin(); }
    match /events/{id} { allow read: if true; allow write: if isAdmin(); }
    match /development_projects/{id} { allow read: if true; allow write: if isAdmin(); }
    match /documents/{id} { allow read: if true; allow write: if isAdmin(); }
    match /profiles/{id} { allow read: if true; allow write: if isAdmin(); }
    match /bible_readings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /site_content/{id} { allow read: if true; allow write: if isAdmin(); }
    match /social_links/{id} { allow read: if true; allow create, update, delete: if isAdmin(); }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && 
                     (request.auth.uid == userId || isAdmin());
    }

    match /members/{userId} {
      allow read, write: if isAdmin() || 
                          (request.auth != null && request.auth.uid == userId);
    }

    match /financial_ledger/{id} {
      allow read, write: if isAdmin();
    }

    match /private_chats/{chatId} {
      allow create: if request.auth != null && 
                     request.auth.uid in request.resource.data.participants;
      allow read, update, delete: if request.auth != null && 
                                    (request.auth.uid in resource.data.participants || isAdmin());

      match /messages/{messageId} {
        allow read: if request.auth != null && 
                     (request.auth.uid in get(/databases/$(database)/documents/private_chats/$(chatId)).data.participants || 
                      isAdmin());
        allow write: if request.auth != null && 
                      (request.auth.uid == resource.data.senderId || 
                       isAdmin() ||
                       (request.method == 'create' && request.auth.uid in get(/databases/$(database)/documents/private_chats/$(chatId)).data.participants));
      }
    }

    match /bulletins/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin() || 
                             (request.auth != null && request.auth.uid == resource.data.authorId);
    }

    // ✅ NEW - Prayer Requests
    match /prayer_requests/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // ✅ NEW - Volunteer Slots
    match /volunteer_slots/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /signups/{userId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ✅ NEW - Announcements
    match /announcements/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ✅ NEW - Giving/Donations
    match /giving/{id} {
      allow create: if request.auth != null;
      allow read: if isAdmin() || 
                   (request.auth != null && request.auth.uid == resource.data.userId);
      allow update, delete: if isAdmin();
    }
  }
}