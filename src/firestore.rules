 rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  // Allow everyone to read content (Bulletin, Events, etc.)
    match /{document=**} {
      allow read: if true;
      // Only allow the Chairman to edit
      allow write: if request.auth != null;
    }

    // Helper to check if user is the super admin (Chairman)
    function isSuperAdmin() {
      return request.auth != null && 
             (request.auth.token.email == 'kimaniemma20@gmail.com' || 
              request.auth.uid == 'BKSmmIdohYQHlao5V9eZ9JQyaEV2');
    }

    // Helper to check if user has admin privileges in their registry profile
    function isAdmin() {
      return isSuperAdmin() || 
        (request.auth != null && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }

    // 1. Site Branding & Configuration
    // Everyone can read branding, only the Super Admin can edit global settings
    match /site_settings/{settingsId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // 2. Public Information Tables
    // Public can read, Admins can manage
    match /masses/{id} { allow read: if true; allow write: if isAdmin(); }
    match /community_groups/{id} { allow read: if true; allow write: if isAdmin(); }
    match /bulletins/{id} { allow read: if true; allow write: if isAdmin(); }
    match /events/{id} { allow read: if true; allow write: if isAdmin(); }
    match /development_projects/{id} { allow read: if true; allow write: if isAdmin(); }
    match /documents/{id} { allow read: if true; allow write: if isAdmin(); }
    match /profiles/{id} { allow read: if true; allow write: if isAdmin(); }
    match /bible_readings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /site_content/{id} { allow read: if true; allow write: if isAdmin(); }

    // 3. Application User Presence
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // 4. Parishioner Registry (Profiles)
    match /members/{userId} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    // 5. Financial Treasury
    match /financial_ledger/{id} {
      allow read, write: if isAdmin();
    }

    // 6. Interactive Features
    match /private_chats/{chatId} {
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow read, update, delete: if request.auth != null && (request.auth.uid in resource.data.participants || isAdmin());

      match /messages/{messageId} {
        allow read, write: if request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/private_chats/$(chatId)).data.participants || isAdmin());
      }
    }

    match /bulletins/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.authorId);
    }
  }
}